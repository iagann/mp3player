<Window x:Class="ObsMonolithPlayer.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist" Height="450" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="#1A1A1A"
        BorderBrush="#333" BorderThickness="1"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#252525" MouseDown="Header_MouseDown">
            <TextBlock Text="ПЛЕЙЛИСТ" Foreground="White" Opacity="0.6" 
                       VerticalAlignment="Center" Margin="10,0" FontSize="10" FontWeight="SemiBold"/>
            <Button Content="✕" HorizontalAlignment="Right" Width="30" Background="Transparent" 
                    BorderThickness="0" Foreground="Gray" Click="BtnClose_Click"/>
        </Grid>

        <Border Grid.Row="1" Background="#202020" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock x:Name="txtPlaceholder" Text="Поиск в библиотеке..." Foreground="Gray" 
                   VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False"
                   Visibility="{Binding Text.IsEmpty, ElementName=txtSearch, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <DockPanel Margin="5,0">
                    <Button x:Name="btnClearSearch" Content="✕" DockPanel.Dock="Right" 
                    Width="25" Background="Transparent" BorderThickness="0" 
                    Foreground="Gray" Cursor="Hand" Click="BtnClearSearch_Click"
                    Visibility="Collapsed"/>
                    <TextBox x:Name="txtSearch" Background="Transparent" Foreground="White" 
                     BorderThickness="0" VerticalAlignment="Center" Margin="5,0"
                     CaretBrush="White" TextChanged="TxtSearch_TextChanged"
                     KeyDown="TxtSearch_KeyDown"/>
                </DockPanel>
            </Grid>
        </Border>

        <ListBox x:Name="lstPlaylist" Grid.Row="2" 
                 Background="Transparent" BorderThickness="0" 
                 Foreground="White" FontSize="13"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="LstPlaylist_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10,8" BorderBrush="#252525" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Foreground="White"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A2A"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#333"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</Window>