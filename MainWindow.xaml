<Window x:Class="ObsMonolithPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="OBS Monolith Player" Height="600" Width="600"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarInfo">
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo Description="Previous" Click="BtnPrev_Click">
                    <ThumbButtonInfo.ImageSource>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Brush="White" Geometry="M0,0 H2 V10 H0 Z M10,0 L4,5 L10,10 Z" />
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </ThumbButtonInfo.ImageSource>
                </ThumbButtonInfo>

                <ThumbButtonInfo x:Name="taskbarPlayPause" Description="Play/Pause" Click="BtnPlayPause_Click">
                    <ThumbButtonInfo.ImageSource>
                        <DrawingImage x:Name="taskbarPlayIcon">
                            <DrawingImage.Drawing>
                                <GeometryDrawing x:Name="taskbarPlayGeometry" Brush="White" Geometry="M0,0 L10,5 L0,10 Z" />
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </ThumbButtonInfo.ImageSource>
                </ThumbButtonInfo>

                <ThumbButtonInfo Description="Next" Click="BtnNext_Click">
                    <ThumbButtonInfo.ImageSource>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Brush="White" Geometry="M0,0 L6,5 L0,10 Z M8,0 H10 V10 H8 Z" />
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </ThumbButtonInfo.ImageSource>
                </ThumbButtonInfo>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>

    <Window.Resources>
        <Style x:Key="SysBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ControlBtn" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="6" Background="{TemplateBinding Background}" CornerRadius="3" VerticalAlignment="Center" Margin="5,0"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#007ACC" Stroke="White" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="337" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#252525" MouseDown="Window_MouseDown">
                <TextBlock Text="MP3 PLAYER" 
                   Foreground="White" 
                   Opacity="0.6" 
                   VerticalAlignment="Center" 
                   Margin="10,0" 
                   FontSize="10" 
                   FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔗" 
                        ToolTip="Прикрепить YouTube видео из буфера" 
                        Style="{StaticResource SysBtn}" 
                        Click="BtnAttachVideo_Click" 
                        Foreground="DodgerBlue"/>
                    <Button Content="—" Style="{StaticResource SysBtn}" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Style="{StaticResource SysBtn}" Click="BtnClose_Click" Foreground="Crimson"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" 
                Background="Transparent" 
                BorderBrush="#333" 
                BorderThickness="1">

                <Grid x:Name="VideoContainer" ClipToBounds="True">
                    <vlc:VideoView x:Name="MainVideoView" 
                       Opacity="0" 
                       Background="Transparent"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#1A1A1A" Padding="15">
                <StackPanel>
                    <Border x:Name="borderTitle" 
                        Height="35" 
                        ClipToBounds="True" 
                        Margin="0,2"
                        Background="#261A1A1A">

                        <Grid x:Name="gridTitle">
                            <TextBlock x:Name="txtCurrentTrack" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Cursor="Hand" 
                                   MouseLeftButtonDown="txtCurrentTrack_MouseLeftButtonDown"
                                   ToolTip="Нажмите, чтобы скопировать название">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="textTransform" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Grid Height="14">
                                    <TextBlock x:Name="txtOrderedBy" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="10" 
                           Foreground="DodgerBlue" 
                           Opacity="0.8" 
                           Visibility="Collapsed"/>
                                </Grid>

                                <TextBlock x:Name="txtNextTrack" 
                       Text="Далее: ---" 
                       FontSize="12" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,0"/>

                    <Slider x:Name="sldProgress" 
                        Style="{StaticResource ModernSlider}" 
                        Minimum="0" 
                        Maximum="1"
                        PreviewMouseLeftButtonDown="sldProgress_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="sldProgress_PreviewMouseLeftButtonUp"
                        MouseMove="sldProgress_MouseMove" />

                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="➕" 
                                Click="BtnAddYouTubeTrack_Click" 
                                Style="{StaticResource SysBtn}" 
                                ToolTip="Заказать трек с YouTube (ссылка из буфера)" 
                                FontSize="14" 
                                Foreground="LightBlue" 
                                Margin="0,0,10,0"/>
                            <Button Content="⏮" Click="BtnPrev_Click" Style="{StaticResource ControlBtn}"/>
                            <Button x:Name="btnPlayPause" Content="⏸" Click="BtnPlayPause_Click" Style="{StaticResource ControlBtn}"/>
                            <Button Content="⏭" Click="BtnNext_Click" Style="{StaticResource ControlBtn}"/>
                            <Button Content="☰" Click="BtnOpenPlaylist_Click" 
                                Style="{StaticResource SysBtn}" 
                                ToolTip="Список треков" 
                                FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="🔊" Foreground="Gray" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <Slider x:Name="sldVolume" 
                                Width="80" 
                                Maximum="100" 
                                Value="50"
                                VerticalAlignment="Center"
                                ValueChanged="sldVolume_ValueChanged" 
                                MouseWheel="sldVolume_MouseWheel"
                                ToolTipService.InitialShowDelay="100"
                                ToolTipService.BetweenShowDelay="0">
                                <Slider.ToolTip>
                                    <ToolTip x:Name="volToolTip" Content="50%"/>
                                </Slider.ToolTip>
                            </Slider>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>